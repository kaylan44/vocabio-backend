# URL de connexion à la base de données Supabase (format PostgreSQL)
# Disponible dans Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# URL de ton projet Supabase (ex: https://xxxx.supabase.co)
# Utilisée pour construire l'URL JWKS : {SUPABASE_URL}/auth/v1/.well-known/jwks.json
SUPABASE_URL="https://xxxx.supabase.co"

# Secret pour vérifier la signature des webhooks Supabase
# Disponible dans Supabase Dashboard > Webhooks > ton webhook > Signing secret
SUPABASE_WEBHOOK_SECRET="your-webhook-secret"

# Port d'écoute du serveur Express (Railway injecte cette variable automatiquement)
PORT=3000
